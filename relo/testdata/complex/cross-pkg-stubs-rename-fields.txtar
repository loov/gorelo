# Cross-package move with stubs, type renames, AND field renames
# all at once. The source package gets stub aliases for the renamed
# type, and remaining source code uses the renamed fields through
# the stub type alias. Consumer packages keep using source stubs.
# The unexported method endpoint() cannot move cross-package and
# stays in the source using the type alias.

@stubs
config=Config config#host=Host config#port=Port newConfig=NewConfig -> dst/config.go

@warn renaming type config to Config will also change embedded field names
@warn unexported method "endpoint" cannot be moved cross-package
@vet undefined: Config

-- input/go.mod --
module example.com/test

go 1.21
-- input/src/config.go --
package src

import "fmt"

type config struct {
	host string
	port int
}

func (c *config) endpoint() string {
	return fmt.Sprintf("%s:%d", c.host, c.port)
}

func newConfig(host string, port int) *config {
	return &config{host: host, port: port}
}

func UseConfig() {
	c := newConfig("localhost", 8080)
	fmt.Println(c.host, c.port)
}
-- input/consumer/consumer.go --
package consumer

import "example.com/test/src"

func Setup() {
	src.UseConfig()
}
-- golden/dst/config.go --
package dst

type Config struct {
	Host string
	Port int
}

func NewConfig(host string, port int) *Config {
	return &Config{Host: host, Port: port}
}
-- golden/src/config.go --
package src

import (
	"fmt"
	"example.com/test/dst"
)

func (c *Config) endpoint() string {
	return fmt.Sprintf("%s:%d", c.Host, c.Port)
}

func UseConfig() {
	c := NewConfig("localhost", 8080)
	fmt.Println(c.Host, c.Port)
}

//go:fix inline
type config = dst.Config

//go:fix inline
func newConfig(host string, port int) *config { return dst.NewConfig(host, port) }
-- golden/consumer/consumer.go --
package consumer

import "example.com/test/src"

func Setup() {
	src.UseConfig()
}
