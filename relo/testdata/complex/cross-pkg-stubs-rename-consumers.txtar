# Cross-package move with stubs, type rename, AND consumer packages
# that directly reference the type by name. Consumers should keep using
# the old name through the stub alias.

@stubs
Config=Settings NewConfig=NewSettings -> dst/config.go

@warn renaming type Config to Settings will also change embedded field names

-- input/go.mod --
module example.com/test

go 1.21
-- input/src/config.go --
package src

import "fmt"

type Config struct {
	Name string
}

func NewConfig(name string) *Config {
	return &Config{Name: name}
}

func (c *Config) Print() {
	fmt.Println(c.Name)
}
-- input/consumer/consumer.go --
package consumer

import "example.com/test/src"

func Setup() *src.Config {
	c := src.NewConfig("test")
	c.Print()
	return c
}
-- golden/dst/config.go --
package dst

import (
	"fmt"
)

type Settings struct {
	Name string
}

func NewSettings(name string) *Settings {
	return &Settings{Name: name}
}

func (c *Settings) Print() {
	fmt.Println(c.Name)
}
-- golden/src/config.go --
package src

import (
	"example.com/test/dst"
)


//go:fix inline
type Config = dst.Settings

//go:fix inline
func NewConfig(name string) *Config { return dst.NewSettings(name) }
-- golden/consumer/consumer.go --
package consumer

import "example.com/test/src"

func Setup() *src.Config {
	c := src.NewConfig("test")
	c.Print()
	return c
}
