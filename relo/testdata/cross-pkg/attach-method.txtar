# Convert a function to a method, moving it to the receiver type's package.
# Start lives in util, Server lives in srv. Attach moves Start to srv.

@method Server
Start -> srv/methods.go

-- input/go.mod --
module example.com/test

go 1.21
-- input/util/funcs.go --
package util

import "example.com/test/srv"

// Start starts the server.
func Start(s *srv.Server) error {
	return nil
}
-- input/srv/server.go --
package srv

type Server struct{}
-- input/consumer/consumer.go --
package consumer

import (
	"example.com/test/srv"
	"example.com/test/util"
)

func Do() {
	s := &srv.Server{}
	util.Start(s)
}
-- golden/srv/server.go --
package srv

type Server struct{}
-- golden/srv/methods.go --
package srv

// Start starts the server.
func (s *Server) Start() error {
	return nil
}
-- golden/consumer/consumer.go --
package consumer

import (
	"example.com/test/srv"
)

func Do() {
	s := &srv.Server{}
	s.Start()
}
