# Move to a package that already imports source, where a sibling in
# source still references the moved decl after the move. The rewrite
# forces src→dst, and dst→src already exists — a real cycle warning.

Helper -> dst/helper.go

@warn may create a circular import
@vet import cycle not allowed

-- input/go.mod --
module example.com/circular

go 1.21
-- input/src/a.go --
package src

// Helper is a helper function.
func Helper() string {
	return "help"
}
-- input/src/consumer.go --
package src

// StillUsesHelper keeps referencing Helper after the move.
func StillUsesHelper() string {
	return Helper()
}
-- input/dst/b.go --
package dst

import "example.com/circular/src"

// UsesStill keeps src importing dst indirectly through the consumer.
func UsesStill() string {
	return src.StillUsesHelper()
}
-- golden/src/consumer.go --
package src

import (
	"example.com/circular/dst"
)

// StillUsesHelper keeps referencing Helper after the move.
func StillUsesHelper() string {
	return dst.Helper()
}
-- golden/dst/helper.go --
package dst

// Helper is a helper function.
func Helper() string {
	return "help"
}
-- golden/dst/b.go --
package dst

import "example.com/circular/src"

// UsesStill keeps src importing dst indirectly through the consumer.
func UsesStill() string {
	return src.StillUsesHelper()
}
