-- input/src/cache.go --
package src

// Cache is a generic cache.
type Cache[K comparable, V any] struct {
	data map[K]V
}

// Get retrieves a value from the cache.
func (c *Cache[K, V]) Get(key K) (V, bool) {
	v, ok := c.data[key]
	return v, ok
}

// Set stores a value in the cache.
func (c *Cache[K, V]) Set(key K, val V) {
	c.data[key] = val
}

func Other() {}
