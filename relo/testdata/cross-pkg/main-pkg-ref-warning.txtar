# Move a function out of package main that references an exported symbol
# staying in main. Since main cannot be imported, the qualification
# produces an import cycle — go vet catches this.

Handler -> dst/handler.go

@warn moved decl Handler references "DefaultAddr" which stays in package main
@vet import cycle not allowed

-- input/go.mod --
module example.com/test

go 1.21
-- input/cmd/main.go --
package main

var DefaultAddr = ":8080"

func Handler() string {
	return DefaultAddr
}

func main() {
	_ = Handler()
}
-- golden/cmd/main.go --
package main

import (
	"example.com/test/dst"
)

var DefaultAddr = ":8080"

func main() {
	_ = dst.Handler()
}
-- golden/dst/handler.go --
package dst

import (
	main "example.com/test/cmd"
)

func Handler() string {
	return main.DefaultAddr
}
