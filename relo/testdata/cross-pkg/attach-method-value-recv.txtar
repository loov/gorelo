# Cross-package attach with a value receiver type (not pointer).

@attach Server
Start -> srv/methods.go

-- input/go.mod --
module example.com/test

go 1.21
-- input/util/funcs.go --
package util

import "example.com/test/srv"

func Start(s srv.Server) error {
	return nil
}
-- input/srv/server.go --
package srv

type Server struct{}
-- golden/srv/server.go --
package srv

type Server struct{}
-- golden/srv/methods.go --
package srv

func (s Server) Start() error {
	return nil
}
