# Moving an unreferenced unexported identifier cross-package is safe.

uuid_ -> dst/ids.go

-- input/go.mod --
module example.com/test

go 1.21
-- input/src/source.go --
package src

var uuid_ = "default-uuid"

func helper() string {
	return "internal"
}
-- golden/dst/ids.go --
package dst

var uuid_ = "default-uuid"
-- golden/src/source.go --
package src

func helper() string {
	return "internal"
}
