# Rename a type, its fields, and methods while moving to a new file.
# Method renames must be on the same line as the type move.

conn=Connection conn#dial=Dial conn#addr=Addr -> connection.go
conn#host=Host
conn#port=Port

@warn renaming type conn to Connection will also change embedded field names

-- input/go.mod --
module example.com/pkg

go 1.21
-- input/conn.go --
package mypkg

import "fmt"

// conn is an internal connection.
type conn struct {
	host string
	port int
}

// dial connects to the remote host.
func (c *conn) dial() error {
	fmt.Printf("dialing %s:%d\n", c.host, c.port)
	return nil
}

// addr returns the address string.
func (c *conn) addr() string {
	return fmt.Sprintf("%s:%d", c.host, c.port)
}
-- input/usage.go --
package mypkg

import "fmt"

// Connect creates a connection and dials.
func Connect(host string, port int) (*conn, error) {
	c := &conn{host: host, port: port}
	if err := c.dial(); err != nil {
		return nil, err
	}
	fmt.Println("connected to", c.addr())
	return c, nil
}
-- golden/connection.go --
package mypkg

import (
	"fmt"
)

// conn is an internal connection.
type Connection struct {
	Host string
	Port int
}

// dial connects to the remote host.
func (c *Connection) Dial() error {
	fmt.Printf("dialing %s:%d\n", c.Host, c.Port)
	return nil
}

// addr returns the address string.
func (c *Connection) Addr() string {
	return fmt.Sprintf("%s:%d", c.Host, c.Port)
}
-- golden/usage.go --
package mypkg

import "fmt"

// Connect creates a connection and dials.
func Connect(host string, port int) (*Connection, error) {
	c := &Connection{Host: host, Port: port}
	if err := c.Dial(); err != nil {
		return nil, err
	}
	fmt.Println("connected to", c.Addr())
	return c, nil
}
