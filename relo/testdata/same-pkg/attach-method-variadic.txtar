# Attaching a function whose first parameter is variadic should warn.

@warn first parameter is variadic
Start=Server#Start

-- input/go.mod --
module example.com/pkg

go 1.21
-- input/server.go --
package mypkg

type Server struct{}

func Start(servers ...*Server) {}
-- golden/server.go --
package mypkg

type Server struct{}

func Start(servers ...*Server) {}
