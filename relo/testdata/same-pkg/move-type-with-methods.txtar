# Move a type and its methods together to a new file.

Server -> server.go

-- input/go.mod --
module example.com/pkg

go 1.21
-- input/types.go --
package mypkg

import (
	"fmt"
	"net/http"
)

// Server handles HTTP requests.
type Server struct {
	Addr string
	mux  *http.ServeMux
}

// Start begins listening.
func (s *Server) Start() error {
	return http.ListenAndServe(s.Addr, s.mux)
}

// Handle registers a handler.
func (s *Server) Handle(pattern string, handler http.Handler) {
	s.mux.Handle(pattern, handler)
}

// PrintAddr prints the server address.
func (s *Server) PrintAddr() {
	fmt.Println("listening on", s.Addr)
}

// Unrelated stays here.
func Unrelated() string {
	return "hello"
}
-- golden/server.go --
package mypkg

import (
	"fmt"
	"net/http"
)

// Server handles HTTP requests.
type Server struct {
	Addr string
	mux  *http.ServeMux
}

// Start begins listening.
func (s *Server) Start() error {
	return http.ListenAndServe(s.Addr, s.mux)
}

// Handle registers a handler.
func (s *Server) Handle(pattern string, handler http.Handler) {
	s.mux.Handle(pattern, handler)
}

// PrintAddr prints the server address.
func (s *Server) PrintAddr() {
	fmt.Println("listening on", s.Addr)
}
-- golden/types.go --
package mypkg

// Unrelated stays here.
func Unrelated() string {
	return "hello"
}
