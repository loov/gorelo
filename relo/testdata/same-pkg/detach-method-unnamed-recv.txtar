# Detach a method with an unnamed receiver.
# The parameter remains unnamed in the detached function.

Server#Start=!

-- input/go.mod --
module example.com/pkg

go 1.21
-- input/server.go --
package mypkg

type Server struct{}

func (*Server) Start() {}

func main() {
	s := &Server{}
	s.Start()
}
-- golden/server.go --
package mypkg

type Server struct{}

func Start(*Server) {}

func main() {
	s := &Server{}
	Start(s)
}
