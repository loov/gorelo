# Move a function with a //go:generate directive — warns about it.

Gen -> generated.go

@warn moved decl Gen has a //go:generate directive

-- input/go.mod --
module example.com/pkg

go 1.21
-- input/source.go --
package mypkg

//go:generate stringer -type=Kind
func Gen() string {
	return "generated"
}

func Other() {}
-- golden/source.go --
package mypkg

func Other() {}
-- golden/generated.go --
package mypkg

//go:generate stringer -type=Kind
func Gen() string {
	return "generated"
}
