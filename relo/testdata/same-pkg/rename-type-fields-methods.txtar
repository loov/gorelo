# Move a type to a new file, rename its fields and a method.
# Method renames must be on the same line as the type move so
# the method inherits the MoveTo. Field renames are separate.

Config Config#GetAddr=Address -> moved.go
Config#host=Host
Config#port=Port

@warn constructor NewConfig exists but is not being moved with type Config

-- input/go.mod --
module example.com/pkg

go 1.21
-- input/source.go --
package mypkg

import "fmt"

// Config holds configuration.
type Config struct {
	host string
	port int
}

// GetAddr returns the address.
func (c *Config) GetAddr() string {
	return fmt.Sprintf("%s:%d", c.host, c.port)
}
-- input/other.go --
package mypkg

import "fmt"

// PrintConfig prints the config.
func PrintConfig(c *Config) {
	fmt.Println(c.host, c.port)
}

// NewConfig creates a Config.
func NewConfig(host string, port int) Config {
	return Config{host: host, port: port}
}
-- golden/moved.go --
package mypkg

import (
	"fmt"
)

// Config holds configuration.
type Config struct {
	Host string
	Port int
}

// GetAddr returns the address.
func (c *Config) Address() string {
	return fmt.Sprintf("%s:%d", c.Host, c.Port)
}
-- golden/other.go --
package mypkg

import "fmt"

// PrintConfig prints the config.
func PrintConfig(c *Config) {
	fmt.Println(c.Host, c.Port)
}

// NewConfig creates a Config.
func NewConfig(host string, port int) Config {
	return Config{Host: host, Port: port}
}
