# Move a const that inherits its value from a previous iota spec.
# Should warn about iota dependency.

Green -> colors_moved.go

@warn const Green depends on iota
@vet missing init expr for Green

-- input/go.mod --
module example.com/pkg

go 1.21
-- input/colors.go --
package mypkg

type Color int

const (
	Red   Color = iota // 0, explicit iota
	Green              // 1, inherited from iota
	Blue               // 2, inherited from iota
)

func Other() {}
-- golden/colors.go --
package mypkg

type Color int

const (
	Red   Color = iota // 0, explicit iota
	Blue               // 2, inherited from iota
)

func Other() {}
-- golden/colors_moved.go --
package mypkg

const Green              // 1, inherited from iota
