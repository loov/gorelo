# Detach with complex receiver expressions in call sites.

Server#Start=!

-- input/go.mod --
module example.com/pkg

go 1.21
-- input/server.go --
package mypkg

type Server struct{}

func (s *Server) Start() error {
	return nil
}

func NewServer() *Server {
	return &Server{}
}

func run() {
	NewServer().Start()
	servers := []*Server{{}}
	servers[0].Start()
}
-- golden/server.go --
package mypkg

type Server struct{}

func Start(s *Server) error {
	return nil
}

func NewServer() *Server {
	return &Server{}
}

func run() {
	Start(NewServer())
	servers := []*Server{{}}
	Start(servers[0])
}
