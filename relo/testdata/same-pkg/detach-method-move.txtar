# Detach a method and move it to a new file.

@detach
Server#Start -> funcs.go

-- input/go.mod --
module example.com/pkg

go 1.21
-- input/server.go --
package mypkg

type Server struct {
	addr string
}

// Start starts the server.
func (s *Server) Start() error {
	return nil
}

func run() {
	s := &Server{addr: ":8080"}
	s.Start()
}
-- golden/funcs.go --
package mypkg

// Start starts the server.
func Start(s *Server) error {
	return nil
}
-- golden/server.go --
package mypkg

type Server struct {
	addr string
}

func run() {
	s := &Server{addr: ":8080"}
	Start(s)
}
