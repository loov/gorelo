# Detach a method that is used as a method value (not called).
# This should produce a warning about signature change.

@warn method value reference
@vet declared and not used
@detach
Server#Start

-- input/go.mod --
module example.com/pkg

go 1.21
-- input/server.go --
package mypkg

type Server struct{}

func (s *Server) Start() error {
	return nil
}

func main() {
	s := &Server{}
	f := s.Start
	_ = f
}
-- golden/server.go --
package mypkg

type Server struct{}

func Start(s *Server) error {
	return nil
}

func main() {
	s := &Server{}
	f := Start
	_ = f
}
