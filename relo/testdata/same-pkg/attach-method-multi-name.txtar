# Attaching a function whose first parameter field has multiple names should warn.

@warn first parameter field has multiple names
Start=Server#Start

-- input/go.mod --
module example.com/pkg

go 1.21
-- input/server.go --
package mypkg

type Server struct{}

func Start(a, b *Server) {}
-- golden/server.go --
package mypkg

type Server struct{}

func Start(a, b *Server) {}
