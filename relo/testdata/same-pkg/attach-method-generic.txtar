# Attaching a generic function as a method should warn.
# Go does not allow type parameters on methods.

@warn generic functions cannot become methods
Start=Server#Start

-- input/go.mod --
module example.com/pkg

go 1.21
-- input/server.go --
package mypkg

type Server struct{}

func Start[T any](s *Server, v T) {}
-- golden/server.go --
package mypkg

type Server struct{}

func Start[T any](s *Server, v T) {}
