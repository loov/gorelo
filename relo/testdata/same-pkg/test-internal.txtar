# Move a test function within an internal _test.go file (same package).

TestHello -> greet_test.go

-- input/go.mod --
module example.com/pkg

go 1.21
-- input/source.go --
package mypkg

func Hello() string   { return "hello" }
func Goodbye() string { return "goodbye" }
-- input/source_test.go --
package mypkg

import "testing"

func TestHello(t *testing.T) {
	if Hello() != "hello" {
		t.Fatal("wrong")
	}
}

func TestGoodbye(t *testing.T) {
	if Goodbye() != "goodbye" {
		t.Fatal("wrong")
	}
}
-- golden/source.go --
package mypkg

func Hello() string   { return "hello" }
func Goodbye() string { return "goodbye" }
-- golden/source_test.go --
package mypkg

import "testing"

func TestGoodbye(t *testing.T) {
	if Goodbye() != "goodbye" {
		t.Fatal("wrong")
	}
}
-- golden/greet_test.go --
package mypkg

import (
	"testing"
)

func TestHello(t *testing.T) {
	if Hello() != "hello" {
		t.Fatal("wrong")
	}
}
