# Move constants with explicit values from a mixed iota/explicit block.
# The tool warns that the block contains iota.

ExplicitA ExplicitB -> explicit_out.go

@warn depends on iota

-- input/go.mod --
module example.com/pkg

go 1.21
-- input/explicit.go --
package mypkg

const (
	ExplicitA = 0
	ExplicitB = 1

	IotaX = iota
	IotaY
	IotaZ
)
-- golden/explicit_out.go --
package mypkg

const (
	ExplicitA = 0
	ExplicitB = 1
)
-- golden/explicit.go --
package mypkg

const (

	IotaX = iota
	IotaY
	IotaZ
)
