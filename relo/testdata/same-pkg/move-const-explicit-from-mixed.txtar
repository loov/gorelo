# Move constants with explicit values from a mixed iota/explicit block.
# The tool treats all consts in an iota-containing block as iota-dependent.

ExplicitA ExplicitB -> explicit_out.go

@error depends on iota

-- input/go.mod --
module example.com/pkg

go 1.21
-- input/explicit.go --
package mypkg

const (
	ExplicitA = 0
	ExplicitB = 1

	IotaX = iota
	IotaY
	IotaZ
)
