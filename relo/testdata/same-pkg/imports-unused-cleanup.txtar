-- input/dates.go --
package util

import (
	"fmt"
	"time"
)

// FormatDate formats a date value.
func FormatDate(t time.Time) string {
	return t.Format(time.DateOnly)
}

// PrintHello prints hello.
func PrintHello() {
	fmt.Println("hello")
}
-- golden/dateutil.go --
package util

import (
	"time"
)

// FormatDate formats a date value.
func FormatDate(t time.Time) string {
	return t.Format(time.DateOnly)
}
