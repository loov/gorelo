# Convert a standalone function to a method.

@method Server
Start

-- input/go.mod --
module example.com/pkg

go 1.21
-- input/server.go --
package mypkg

type Server struct {
	addr string
}

// Start starts the server.
func Start(s *Server) error {
	return nil
}

func main() {
	s := &Server{addr: ":8080"}
	Start(s)
}
-- golden/server.go --
package mypkg

type Server struct {
	addr string
}

// Start starts the server.
func (s *Server) Start() error {
	return nil
}

func main() {
	s := &Server{addr: ":8080"}
	s.Start()
}
