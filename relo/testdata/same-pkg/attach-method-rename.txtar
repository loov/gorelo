# Convert a function to a method with rename.

@method Server
StartServer=Start

-- input/go.mod --
module example.com/pkg

go 1.21
-- input/server.go --
package mypkg

type Server struct {
	addr string
}

func StartServer(s *Server) error {
	return nil
}

func main() {
	s := &Server{addr: ":8080"}
	StartServer(s)
}
-- golden/server.go --
package mypkg

type Server struct {
	addr string
}

func (s *Server) Start() error {
	return nil
}

func main() {
	s := &Server{addr: ":8080"}
	s.Start()
}
