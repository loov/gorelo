# Extract iota-based consts from a mixed const block that also
# contains string and integer consts. The iota values will change
# in the new file since iota resets per const block.

Monday Tuesday Wednesday -> days.go

@warn depends on iota

-- input/go.mod --
module example.com/pkg

go 1.21
-- input/consts.go --
package pkg

const (
	Alpha = "a"
	Beta  = "b"

	// These are days of the week
	Monday = iota
	Tuesday // Tuesday is the second day of the week
	Wednesday

	ErrorCode = 123
)
-- golden/days.go --
package pkg

const (
	// These are days of the week
	Monday = iota
	Tuesday // Tuesday is the second day of the week
	Wednesday
)
-- golden/consts.go --
package pkg

const (
	Alpha = "a"
	Beta  = "b"


	ErrorCode = 123
)
