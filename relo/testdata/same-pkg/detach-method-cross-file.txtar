# Detach a method, call sites in a different file.

@detach
Server#Start

-- input/go.mod --
module example.com/pkg

go 1.21
-- input/server.go --
package mypkg

type Server struct {
	addr string
}

// Start starts the server.
func (s *Server) Start() error {
	return nil
}
-- input/main.go --
package mypkg

func run() {
	s := &Server{addr: ":8080"}
	s.Start()
}
-- golden/server.go --
package mypkg

type Server struct {
	addr string
}

// Start starts the server.
func Start(s *Server) error {
	return nil
}
-- golden/main.go --
package mypkg

func run() {
	s := &Server{addr: ":8080"}
	Start(s)
}
