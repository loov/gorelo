# Move and rename a type that is used as an embedded field.
# Composite literal keys referencing the embedded field name must be
# updated in the extracted (moved) code.

Base=Foundation -> moved.go

@warn renaming type Base to Foundation will also change embedded field names

-- input/go.mod --
module example.com/pkg

go 1.21
-- input/types.go --
package pkg

// Base holds common fields.
type Base struct {
	ID   int
	Name string
}

// Container embeds Base.
type Container struct {
	Base
	Extra string
}

// NewContainer creates a Container with embedded Base fields.
func NewContainer() Container {
	b := Base{ID: 1, Name: "test"}
	return Container{
		Base:  b,
		Extra: "more",
	}
}
-- golden/types.go --
package pkg

// Container embeds Base.
type Container struct {
	Foundation
	Extra string
}

// NewContainer creates a Container with embedded Base fields.
func NewContainer() Container {
	b := Foundation{ID: 1, Name: "test"}
	return Container{
		Foundation:  b,
		Extra: "more",
	}
}
-- golden/moved.go --
package pkg

// Base holds common fields.
type Foundation struct {
	ID   int
	Name string
}
