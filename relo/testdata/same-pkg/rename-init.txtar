# Rename init to Setup warns about losing automatic execution semantics.
# Also rename setupDB to init warns about gaining automatic execution.

init=Setup -> lifecycle.go

@warn renaming init function "init" loses automatic execution semantics

-- input/go.mod --
module example.com/pkg

go 1.21
-- input/funcs.go --
package mypkg

import "fmt"

func init() {
	fmt.Println("initializing defaults")
}

// setupDB prepares the database connection.
func setupDB() {
	fmt.Println("connecting to database")
}

// Other stays behind.
func Other() {}
-- golden/lifecycle.go --
package mypkg

import (
	"fmt"
)

func Setup() {
	fmt.Println("initializing defaults")
}
-- golden/funcs.go --
package mypkg

import "fmt"

// setupDB prepares the database connection.
func setupDB() {
	fmt.Println("connecting to database")
}

// Other stays behind.
func Other() {}
