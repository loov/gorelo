# Move a constant from a multi-name const spec.
# All names in the spec move together.

A B -> moved.go

@warn A is part of a multi-name declaration
@warn B is part of a multi-name declaration

-- input/go.mod --
module example.com/pkg

go 1.21
-- input/source.go --
package mypkg

const A, B = 1, 2

var C = 3
-- golden/moved.go --
package mypkg

const A, B = 1, 2
-- golden/source.go --
package mypkg

var C = 3
