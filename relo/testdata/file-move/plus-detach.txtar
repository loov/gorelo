# File move combined with detaching a method in the moved file.

src/server.go -> dst/server.go
Server#Start=!

-- input/go.mod --
module example.com/test

go 1.21
-- input/src/server.go --
package src

// Server handles requests.
type Server struct {
	Addr string
}

// Start begins listening.
func (s *Server) Start() error {
	return nil
}
-- input/src/use.go --
package src

func Use() error {
	s := &Server{Addr: "localhost"}
	return s.Start()
}
-- golden/src/use.go --
package src

import (
	"example.com/test/dst"
)

func Use() error {
	s := &dst.Server{Addr: "localhost"}
	return dst.Start(s)
}
-- golden/dst/server.go --
package dst

// Server handles requests.
type Server struct {
	Addr string
}

// Start begins listening.
func Start(s *Server) error {
	return nil
}
